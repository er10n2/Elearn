<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="/js/form-helper.js"></script>
</head>
<body>

    <%- include('partials/navbar.ejs') %>

    <main>
    <section class="hero-section">
        <div class="hero-overlay">
            <div class="hero-content">
                <h1>Ignite Your Future</h1>
                <p>Discover a world of knowledge and opportunity with Elearn.</p>
          <% if (!locals.user) { %>
        <a href="/register" class="btn-hero">Join Now</a>
    <% } else { %>
        <p>Welcome back, <%= user.email %>!</p>
    <% } %>
            </div>
        </div>
    </section>
    <section class="courses-container">
    <h2 class="section-title">Available Courses</h2>
    
    <!-- Message Display Area for Enrollment -->
    <div class="message-container" style="margin-bottom: 30px;"></div>

    <div class="courses-grid">
        <% Allcourses.forEach(course => { %>
            <div class="course-card">
                <div class="course-content">
                    <h3 class="course-title"><%= course.title %></h3>
                    <p class="professor-name">
            By: Prof. <%= course.name %> <%= course.lastname %>
        </p>
                    <p class="course-description"><%= course.description %></p>
                <form class="enrollForm" action="/enroll" method="POST">
            <input type="hidden" name="courseId" value="<%= course.id %>">
            <button type="submit" class="btn-view">Enroll Now</button>
        </form>
                </div>
            </div>
        <% }); %>
    </div>
</section>
</main>

<script>
    // Set up all enrollment forms
    document.querySelectorAll('.enrollForm').forEach(form => {
        form.addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const messageContainer = document.querySelector('.message-container');
            
            try {
                const formData = new FormData(form);
                const courseId = formData.get('courseId');
                const response = await fetch(form.action, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ courseId })
                });
                
                const data = await response.json();
                
                if (response.ok) {
                    showMessage(messageContainer, data.message, 'success');
                } else {
                    if (response.status === 401) {
                        showMessage(messageContainer, data.message + ' Redirecting to login...', 'error');
                        setTimeout(() => {
                            window.location.href = '/login';
                        }, 2000);
                    } else {
                        showMessage(messageContainer, data.message, 'error');
                    }
                }
            } catch (error) {
                console.error('Error:', error);
                showMessage(messageContainer, 'Something went wrong. Please try again.', 'error');
            }
        });
    });

    // Helper function to display messages
    function showMessage(container, message, type) {
        container.innerHTML = '';
        
        const messageDiv = document.createElement('div');
        messageDiv.className = `message message-${type}`;
        
        const icon = type === 'success' ? '✓' : '✕';
        messageDiv.innerHTML = `
            <span>${icon}</span>
            <span>${message}</span>
            <span class="close-message" onclick="this.parentElement.style.display='none';">&times;</span>
        `;
        
        container.appendChild(messageDiv);
        
        // Auto-hide error messages after 5 seconds
        if (type === 'error') {
            setTimeout(() => {
                if (messageDiv.parentElement) {
                    messageDiv.style.display = 'none';
                }
            }, 5000);
        }
        
        // Scroll to message
        container.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
</script>

</body>
</html>


    <%- include('partials/footer.ejs') %>
</body>
</html>