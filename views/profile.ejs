<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile | Elearn</title>
    <link rel="stylesheet" href="/css/dashboard.css">
    <link rel="stylesheet" href="/css/style.css">
    <script src="/js/form-helper.js"></script>
</head>
<body>

    <%- include('partials/navbar.ejs') %>

    <% if(locals.user) { %>
    <main class="dashboard-wrapper">
        <div class="dashboard-container">
            
            <header class="dashboard-header">
                <div class="header-icon">👤</div>
                <h1>Your Profile</h1>
                <p>Update your personal information below.</p>
            </header>

            <section class="profile-section">
                <h3>Personal Information</h3>
                
                <!-- Message Display Area -->
                <div class="message-container"></div>

                <form id="profileForm" action="/update-profile" method="POST" class="course-form">
                    <div class="form-group">
                        <label for="firstName">First Name</label>
                        <input type="text" id="firstName" name="firstName" value="<%= user.name %>" required>
                    </div>

                    <div class="form-group">
                        <label for="lastName">Last Name</label>
                        <input type="text" id="lastName" name="lastName" value="<%= user.lastname %>" required>
                    </div>

                    <div class="form-group">
                        <label for="email">Email Address</label>
                        <input type="email" id="email" name="email" value="<%= user.email %>" required>
                    </div>

                    <% if(user.role === 'professor') { %>
                        <div class="form-group">
                            <label for="department">Department</label>
                            <input type="text" id="department" name="department" value="<%= user.department %>">
                        </div>
                    <% } else { %>
                        <div class="form-group">
                            <label for="major">Major</label>
                            <input type="text" id="major" name="major" value="<%= user.major %>">
                        </div>
                    <% } %>

                    <button type="submit" class="btn-submit">
                        <span>Save Profile Changes</span>
                        <i class="arrow-icon">✓</i>
                    </button>
                </form>
            </section>

            <hr style="border: 0; border-top: 1px solid #eee; margin: 40px 0;">

            <section class="password-section">
                <header class="dashboard-header" style="text-align: left; padding: 0; margin-bottom: 20px;">
                    <h3>Security</h3>
                    <p>Change your password to keep your account secure.</p>
                </header>

                <!-- Message Display Area for Password -->
                <div class="message-container"></div>

                <form id="passwordForm" action="/update-password" method="POST" class="course-form">
                    <div class="form-group">
                        <label for="currentPassword">Current Password</label>
                        <input type="password" id="currentPassword" name="currentPassword" required>
                    </div>

                    <div class="form-group">
                        <label for="newPassword">New Password</label>
                        <input type="password" id="newPassword" name="newPassword" required>
                    </div>

                    <div class="form-group">
                        <label for="confirmPassword">Confirm New Password</label>
                        <input type="password" id="confirmPassword" name="confirmPassword" required>
                    </div>

                    <button type="submit" class="btn-submit" style="background-color: #2c3e50;">
                        <span>Update Password</span>
                        <i class="arrow-icon">🔒</i>
                    </button>
                </form>
            </section>

        </div>
    </main>
    <% } %>

    <%- include('partials/footer.ejs') %>

    <script>
        // Set up profile form
        const profileForm = document.getElementById('profileForm');
        if (profileForm) {
            // Get the message container for this form
            const messageContainer = profileForm.previousElementSibling;
            
            profileForm.addEventListener('submit', async function(e) {
                e.preventDefault();
                
                try {
                    const formData = new FormData(profileForm);
                    const response = await fetch(profileForm.action, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({
                             firstName: formData.get('firstName'),
        lastName: formData.get('lastName'),
        email: formData.get('email'),
        department: formData.get('department'),
        major: formData.get('major')
                        })
                    });
                    
                    const data = await response.json();
                    
                    if (response.ok) {
                        showMessage(messageContainer, data.message, 'success');
                    } else {
                        if (response.status === 401) {
                            showMessage(messageContainer, data.message + ' Redirecting to login...', 'error');
                            setTimeout(() => {
                                window.location.href = '/login';
                            }, 2000);
                        } else {
                            showMessage(messageContainer, data.message, 'error');
                        }
                    }
                } catch (error) {
                    console.error('Error:', error);
                    showMessage(messageContainer, 'Something went wrong. Please try again.', 'error');
                }
            });
        }

        // Set up password form
        const passwordForm = document.getElementById('passwordForm');
        if (passwordForm) {
            // Get the message container for this form
            const messageContainer = passwordForm.previousElementSibling;
            
            passwordForm.addEventListener('submit', async function(e) {
                e.preventDefault();
                
                try {
                    const formData = new FormData(passwordForm);
                    const response = await fetch(passwordForm.action, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                       body: JSON.stringify({
    currentPassword: formData.get('currentPassword'),
    newPassword: formData.get('newPassword'),
    confirmPassword: formData.get('confirmPassword')
})
                    });
                    
                    const data = await response.json();
                    
                    if (response.ok) {
                        showMessage(messageContainer, data.message, 'success');
                        passwordForm.reset(); // Clear form
                    } else {
                        if (response.status === 401) {
                            showMessage(messageContainer, data.message + ' Redirecting to login...', 'error');
                            setTimeout(() => {
                                window.location.href = '/login';
                            }, 2000);
                        } else {
                            showMessage(messageContainer, data.message, 'error');
                        }
                    }
                } catch (error) {
                    console.error('Error:', error);
                    showMessage(messageContainer, 'Something went wrong. Please try again.', 'error');
                }
            });
        }

        // Helper function to display messages
        function showMessage(container, message, type) {
            container.innerHTML = '';
            
            const messageDiv = document.createElement('div');
            messageDiv.className = `message message-${type}`;
            
            const icon = type === 'success' ? '✓' : '✕';
            messageDiv.innerHTML = `
                <span>${icon}</span>
                <span>${message}</span>
                <span class="close-message" onclick="this.parentElement.style.display='none';">&times;</span>
            `;
            
            container.appendChild(messageDiv);
            
            // Auto-hide error messages after 5 seconds
            if (type === 'error') {
                setTimeout(() => {
                    if (messageDiv.parentElement) {
                        messageDiv.style.display = 'none';
                    }
                }, 5000);
            }
        }
    </script>

</body>
</html>