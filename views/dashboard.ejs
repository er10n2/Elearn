<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Professor Dashboard</title>
    <link rel="stylesheet" href="/css/dashboard.css">
    <link rel="stylesheet" href="/css/style.css">
    <script src="/js/form-helper.js"></script>
</head>
<body>
    <%- include('partials/navbar.ejs') %>
<main class="dashboard-wrapper">
    <div class="dashboard-container">
        <header class="dashboard-header">
            <div class="header-icon">📚</div>
            <h1>Create a New Course</h1>
            <p>Publish your knowledge and start teaching today.</p>
        </header>

        <!-- Message Display Area -->
        <div class="message-container"></div>

        <form id="courseForm" action="/create-course" method="POST" class="course-form">
            <div class="form-group">
                <label for="title">Course Title</label>
                <input type="text" id="title" name="title" placeholder="e.g. Master PostgreSQL Architecture" required>
            </div>

            <div class="form-group">
                <label for="description">Course Description</label>
                <textarea id="description" name="description" rows="6" placeholder="What are the key learning outcomes?..." required></textarea>
            </div>

            <button type="submit" class="btn-submit">
                <span>Deploy Course</span>
                <i class="arrow-icon">→</i>
            </button>
        </form>
    </div>
</main>
    <%- include('partials/footer.ejs') %>

    <script>
        const courseForm = document.getElementById('courseForm');
        const messageContainer = document.querySelector('.message-container');

        if (courseForm) {
            courseForm.addEventListener('submit', async function(e) {
                e.preventDefault();
                
                try {
                    const formData = new FormData(courseForm);
                    const response = await fetch(courseForm.action, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({
                            title: formData.get('title'),
                            description: formData.get('description')
                        })
                    });
                    
                    const data = await response.json();
                    
                    if (response.ok) {
                        showMessage(messageContainer, data.message, 'success');
                        courseForm.reset(); // Clear the form
                    } else {
                        if (response.status === 401) {
                            showMessage(messageContainer, data.message + ' Redirecting to login...', 'error');
                            setTimeout(() => {
                                window.location.href = '/login';
                            }, 2000);
                        } else {
                            showMessage(messageContainer, data.message, 'error');
                        }
                    }
                } catch (error) {
                    console.error('Error:', error);
                    showMessage(messageContainer, 'Something went wrong. Please try again.', 'error');
                }
            });
        }

        // Helper function to display messages
        function showMessage(container, message, type) {
            container.innerHTML = '';
            
            const messageDiv = document.createElement('div');
            messageDiv.className = `message message-${type}`;
            
            const icon = type === 'success' ? '✓' : '✕';
            messageDiv.innerHTML = `
                <span>${icon}</span>
                <span>${message}</span>
                <span class="close-message" onclick="this.parentElement.style.display='none';">&times;</span>
            `;
            
            container.appendChild(messageDiv);
            
            // Auto-hide error messages after 5 seconds
            if (type === 'error') {
                setTimeout(() => {
                    if (messageDiv.parentElement) {
                        messageDiv.style.display = 'none';
                    }
                }, 5000);
            }
        }
    </script>

</body>
</html>